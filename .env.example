# Example environment variables (no secrets). Copy to .env.local and fill values.

# Database
DATABASE_URL=postgresql://<USER>:<PASSWORD>@<HOST>:<PORT>/<DB_NAME>

# Global
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk (Authentication)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_example
CLERK_SECRET_KEY=sk_test_example
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Mux (Video Processing)
MUX_TOKEN_ID=<MUX_TOKEN_ID>
MUX_TOKEN_SECRET=<MUX_TOKEN_SECRET>
MUX_WEBHOOK_SECRET=<MUX_WEBHOOK_SECRET>

# OpenAI / OpenRouter (AI Features)
OPENROUTER_API_KEY=<OPENROUTER_API_KEY>
OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# Upstash (Redis & Workflows)
UPSTASH_REDIS_REST_URL=https://<your-upstash-redis-url>
UPSTASH_REDIS_REST_TOKEN=<your-upstash-token>
UPSTASH_WORKFLOW_URL=https://<your-workflow-url>
QSTASH_TOKEN=<qstash-token>

# Replicate (AI Models)
REPLICATE_API_KEY=<REPLICATE_API_KEY>

# UploadThing (File Uploads)
UPLOADTHING_TOKEN=<UPLOADTHING_TOKEN>

# Cloudinary
CLOUDINARY_CLOUD_NAME=<cloud_name>
CLOUDINARY_API_KEY=<api_key>
CLOUDINARY_API_SECRET=<api_secret>

NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=<cloud_name>
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=<upload_preset>

# Notes:
# - Copy this file to .env.local and fill actual secrets.
# - Never commit .env.local. Add .env.local to .gitignore.